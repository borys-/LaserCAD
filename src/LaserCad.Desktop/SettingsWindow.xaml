<Window x:Class="LaserCad.Desktop.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ustawienia"
        Height="360"
        Width="480"
        MinHeight="320"
        MinWidth="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F4F6F8"
        FontFamily="Segoe UI"
        FontSize="12">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBorderBrush" Color="#D9DEE5" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6B7280" />
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#C8D0DA" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Background" Value="#F9FAFB" />
            <Setter Property="BorderBrush" Value="#C8D0DA" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Bottom"
                Background="#FFFFFF"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Zamknij" Width="96" Click="Close_Click" />
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="18">
                <TextBlock Text="Ustawienia aplikacji"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4" />
                <TextBlock Text="Podstawowe preferencje lokalne dla shell i viewportu."
                           Foreground="{StaticResource MutedTextBrush}"
                           Margin="0,0,0,18" />

                <Border Background="#FFFFFF"
                        BorderBrush="{StaticResource AppBorderBrush}"
                        BorderThickness="1"
                        Padding="14"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Widok roboczy"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10" />
                        <CheckBox x:Name="StartWithGridCheckBox"
                                  Content="Wlacz grid po starcie"
                                  IsChecked="True" />
                        <CheckBox x:Name="StartMaximizedCheckBox"
                                  Content="Uruchamiaj okno zmaksymalizowane" />
                    </StackPanel>
                </Border>

                <Border Background="#FFFFFF"
                        BorderBrush="{StaticResource AppBorderBrush}"
                        BorderThickness="1"
                        Padding="14">
                    <StackPanel>
                        <TextBlock Text="Jednostki"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10" />
                        <TextBlock Text="Jednostka wyswietlania"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="11"
                                   Margin="0,0,0,3" />
                        <ComboBox x:Name="DisplayUnitComboBox" SelectedIndex="0">
                            <ComboBoxItem Content="Milimetry" />
                        </ComboBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
