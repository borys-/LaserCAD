<Window x:Class="LaserCad.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Laser CAD" Height="720" Width="1180"
        MinHeight="560" MinWidth="920"
        Loaded="Window_Loaded"
        Activated="Window_Activated"
        StateChanged="Window_StateChanged">
    <DockPanel LastChildFill="True">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New" />
                <MenuItem Header="_Open..." />
                <MenuItem Header="_Save" />
                <Separator />
                <MenuItem Header="E_xit" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Click="Undo_Click" />
                <MenuItem Header="_Redo" Click="Redo_Click" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Reset View" Click="ResetView_Click" />
                <MenuItem Header="_Zoom To Fit" Click="ZoomToFit_Click" />
                <MenuItem Header="_Grid" IsCheckable="True" IsChecked="True" Click="Grid_Click" />
            </MenuItem>
            <MenuItem Header="_Export">
                <MenuItem Header="Export _SVG..." Click="ExportSvg_Click" />
                <MenuItem Header="Export _DXF..." Click="ExportDxf_Click" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About Laser CAD" />
            </MenuItem>
        </Menu>

        <ToolBarTray DockPanel.Dock="Top" Background="#E6EAEE">
            <ToolBar>
                <Button Content="New" Padding="10,4" />
                <Button Content="Open" Padding="10,4" />
                <Button Content="Save" Padding="10,4" />
                <Separator />
                <Button Content="Rect" Padding="10,4" Click="AddRectangle_Click" />
                <Button Content="Line" Padding="10,4" Click="AddLine_Click" />
                <Button Content="Circle" Padding="10,4" Click="AddCircle_Click" />
                <Button Content="Delete" Padding="10,4" Click="DeleteSelected_Click" />
                <Separator />
                <Button Content="SVG" Padding="10,4" Click="ExportSvg_Click" />
                <Button Content="DXF" Padding="10,4" Click="ExportDxf_Click" />
            </ToolBar>
        </ToolBarTray>

        <Grid Background="#F3F5F7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Background="#FFFFFF">
                <StackPanel Margin="12">
                    <GroupBox Header="Parametry pudelka" Margin="0,0,0,12">
                        <StackPanel Margin="10">
                            <TextBlock Text="Szerokosc" />
                            <TextBox x:Name="BoxWidthTextBox" Text="100" Margin="0,2,0,8" />
                            <TextBlock Text="Glebokosc" />
                            <TextBox x:Name="BoxDepthTextBox" Text="80" Margin="0,2,0,8" />
                            <TextBlock Text="Wysokosc" />
                            <TextBox x:Name="BoxHeightTextBox" Text="50" Margin="0,2,0,8" />
                            <TextBlock Text="Grubosc materialu" />
                            <TextBox x:Name="MaterialThicknessTextBox" Text="3" Margin="0,2,0,8" />
                            <TextBlock Text="Kerf" />
                            <TextBox x:Name="KerfTextBox" Text="0" Margin="0,2,0,8" />
                            <TextBlock Text="Szerokosc palca" />
                            <TextBox x:Name="FingerWidthTextBox" Text="10" Margin="0,2,0,8" />
                            <TextBlock Text="Clearance" />
                            <TextBox x:Name="ClearanceTextBox" Text="0" Margin="0,2,0,8" />
                            <Button Content="Przebuduj" Click="RebuildBoxButton_Click" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Material i warstwy">
                        <StackPanel Margin="10">
                            <ComboBox x:Name="MaterialProfileComboBox"
                                      DisplayMemberPath="Name"
                                      SelectionChanged="MaterialProfileComboBox_SelectionChanged"
                                      Margin="0,0,0,8" />
                            <ItemsControl x:Name="LayersItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <TextBlock Text="{Binding Name}" Width="90" />
                                            <TextBlock Text="{Binding Role}" Width="70" Foreground="#5D6875" />
                                            <TextBlock Text="{Binding Color.Hex}" Foreground="#5D6875" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Transformacje" Margin="0,12,0,0">
                        <StackPanel Margin="10">
                            <TextBlock Text="Przesuniecie X / Y" />
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,8">
                                <TextBox x:Name="MoveXTextBox" Text="10" Width="106" Margin="0,0,8,0" />
                                <TextBox x:Name="MoveYTextBox" Text="0" Width="106" />
                            </StackPanel>
                            <Button Content="Przesun zaznaczone" Click="MoveSelected_Click" Margin="0,0,0,8" />
                            <TextBlock Text="Obrot w stopniach" />
                            <TextBox x:Name="RotateDegreesTextBox" Text="15" Margin="0,2,0,8" />
                            <Button Content="Obroc zaznaczone" Click="RotateSelected_Click" Margin="0,0,0,8" />
                            <TextBlock Text="Skala X / Y" />
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,8">
                                <TextBox x:Name="ScaleXTextBox" Text="1,1" Width="106" Margin="0,0,8,0" />
                                <TextBox x:Name="ScaleYTextBox" Text="1,1" Width="106" />
                            </StackPanel>
                            <Button Content="Skaluj zaznaczone" Click="ScaleSelected_Click" />
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="1" Margin="12" BorderBrush="#CFD6DE" BorderThickness="1" Background="#151515">
                <Grid>
                    <wfi:WindowsFormsHost x:Name="ViewportHost" />
                    <TextBlock x:Name="ViewportPlaceholderTextBlock"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="18"
                               Foreground="#9AA4AF"
                               Text="Ladowanie widoku..." />
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Background="#FFFFFF">
                <StackPanel Margin="12">
                    <GroupBox Header="Historia" Margin="0,0,0,12">
                        <StackPanel Margin="10">
                            <TextBlock x:Name="UndoCountTextBlock" Text="Undo: 0" />
                            <TextBlock x:Name="RedoCountTextBlock" Text="Redo: 0" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Undo" Click="Undo_Click" Width="110" Margin="0,0,8,0" />
                                <Button Content="Redo" Click="Redo_Click" Width="110" />
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Properties">
                        <StackPanel Margin="10">
                            <TextBlock x:Name="DocumentNameTextBlock" Text="Dokument: Projekt pudelka" />
                            <TextBlock x:Name="SketchCountTextBlock" Text="Szkice: 1" />
                            <TextBlock x:Name="SelectedEntitiesTextBlock" Text="Zaznaczone: 0" />
                            <Button Content="Odswiez zaznaczenie" Click="RefreshSelection_Click" Margin="0,8,0,0" />
                            <TextBlock x:Name="StatusTextBlock" Text="Gotowe" Margin="0,8,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
