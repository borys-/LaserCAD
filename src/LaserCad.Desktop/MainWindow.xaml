<Window x:Class="LaserCad.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Laser CAD" Height="860" Width="1440"
        MinHeight="620" MinWidth="1040"
        Background="#F4F6F8"
        FontFamily="Segoe UI"
        FontSize="12"
        Loaded="Window_Loaded"
        Activated="Window_Activated"
        StateChanged="Window_StateChanged">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBorderBrush" Color="#D9DEE5" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6B7280" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />

        <Style TargetType="Menu">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="6,2" />
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Foreground" Value="#1F2937" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2937" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="#F9FAFB" />
            <Setter Property="BorderBrush" Value="#C8D0DA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Background" Value="#F9FAFB" />
            <Setter Property="BorderBrush" Value="#C8D0DA" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#C8D0DA" />
            <Setter Property="Foreground" Value="#1F2937" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="38" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ToolbarAccentButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="#EFF6FF" />
            <Setter Property="BorderBrush" Value="#BFDBFE" />
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="{StaticResource PanelBackgroundBrush}"
                                BorderBrush="{StaticResource AppBorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="14,12">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top"
                                           Text="{TemplateBinding Header}"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           Foreground="#111827"
                                           Margin="0,0,0,10" />
                                <ContentPresenter />
                            </DockPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelScrollStyle" TargetType="ScrollViewer">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
        </Style>

        <Style x:Key="ViewportLoadingBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="4" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="#E5EAF1" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New" InputGestureText="Ctrl+N" Click="NewProject_Click" />
                <MenuItem Header="_Open..." InputGestureText="Ctrl+O" Click="OpenProject_Click" />
                <MenuItem Header="_Save" InputGestureText="Ctrl+S" Click="SaveProject_Click" />
                <MenuItem Header="Save _As..." Click="SaveProjectAs_Click" />
                <Separator />
                <MenuItem Header="E_xit" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" InputGestureText="Ctrl+Z" Click="Undo_Click" />
                <MenuItem Header="_Redo" InputGestureText="Ctrl+Y" Click="Redo_Click" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Reset View" InputGestureText="Home" Click="ResetView_Click" />
                <MenuItem Header="_Zoom To Fit" InputGestureText="Ctrl+0" Click="ZoomToFit_Click" />
                <MenuItem Header="_Grid" IsCheckable="True" IsChecked="True" Click="Grid_Click" />
                <MenuItem Header="_Clean Workspace" Click="CleanWorkspace_Click" />
                <Separator />
                <MenuItem x:Name="BoxGeneratorPanelMenuItem"
                          Header="Box _Generator Panel"
                          IsCheckable="True"
                          Click="BoxGeneratorPanel_Click" />
                <MenuItem x:Name="TemplateLibraryPanelMenuItem"
                          Header="_Template Library Panel"
                          IsCheckable="True"
                          Click="TemplateLibraryPanel_Click" />
                <MenuItem x:Name="AdvancedPanelsMenuItem"
                          Header="_Advanced Panels"
                          IsCheckable="True"
                          Click="AdvancedPanels_Click" />
                <MenuItem x:Name="HistoryPanelMenuItem"
                          Header="_History Panel"
                          IsCheckable="True"
                          Click="HistoryPanel_Click" />
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Settings..." InputGestureText="Ctrl+," Click="Settings_Click" />
            </MenuItem>
            <MenuItem Header="_Export">
                <MenuItem Header="Export _SVG..." InputGestureText="Ctrl+Shift+S" Click="ExportSvg_Click" />
                <MenuItem Header="Export _DXF..." InputGestureText="Ctrl+Shift+D" Click="ExportDxf_Click" />
                <MenuItem Header="Export _Nested DXF..." Click="ExportNestedDxf_Click" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About Laser CAD" Click="About_Click" />
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Top" Background="#FFFFFF" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel Height="52" LastChildFill="True">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Button Content="&#xE710;" ToolTip="Nowy projekt" Style="{StaticResource ToolbarButtonStyle}" Click="NewProject_Click" />
                    <Button Content="&#xE8E5;" ToolTip="Otworz projekt" Style="{StaticResource ToolbarButtonStyle}" Click="OpenProject_Click" />
                    <Button Content="&#xE74E;" ToolTip="Zapisz projekt" Style="{StaticResource ToolbarButtonStyle}" Click="SaveProject_Click" />
                    <Border Width="1" Height="24" Background="{StaticResource AppBorderBrush}" Margin="10,0" />
                    <Button Content="&#xE7C9;" ToolTip="Zaznaczanie" Style="{StaticResource ToolbarAccentButtonStyle}" Click="SelectTool_Click" />
                    <Button Content="&#xE80F;" ToolTip="Czysty widok roboczy" Style="{StaticResource ToolbarButtonStyle}" Click="CleanWorkspace_Click" />
                    <Button Content="&#xE739;" ToolTip="Rysuj prostokat" Style="{StaticResource ToolbarButtonStyle}" Click="AddRectangle_Click" />
                    <Button Content="&#xE8A9;" ToolTip="Rysuj plyte materialowa 3D" Style="{StaticResource ToolbarButtonStyle}" Click="AddMaterialPlate_Click" />
                    <Button Content="&#xE8B9;" ToolTip="Bryla trapezowa" Style="{StaticResource ToolbarButtonStyle}" Click="AddSlopedMaterialSolid_Click" />
                    <Button Content="&#xE8A1;" ToolTip="Rysuj linie" Style="{StaticResource ToolbarButtonStyle}" Click="AddLine_Click" />
                    <Button Content="&#xEA3A;" ToolTip="Rysuj okrag" Style="{StaticResource ToolbarButtonStyle}" Click="AddCircle_Click" />
                    <Button Content="&#xE74D;" ToolTip="Usun zaznaczone" Style="{StaticResource ToolbarButtonStyle}" Click="DeleteSelected_Click" />
                    <Border Width="1" Height="24" Background="{StaticResource AppBorderBrush}" Margin="10,0" />
                    <Button Content="&#xEDE1;" ToolTip="Eksport SVG" Style="{StaticResource ToolbarButtonStyle}" Click="ExportSvg_Click" />
                    <Button Content="&#xEDE2;" ToolTip="Eksport DXF" Style="{StaticResource ToolbarButtonStyle}" Click="ExportDxf_Click" />
                </StackPanel>

                <TextBlock x:Name="StatusTextBlock"
                           DockPanel.Dock="Right"
                           Text="Gotowe"
                           Foreground="{StaticResource MutedTextBrush}"
                           VerticalAlignment="Center"
                           TextAlignment="Right"
                           TextWrapping="NoWrap"
                           Margin="12,0,16,0" />
            </DockPanel>
        </Border>

        <Grid Background="#F4F6F8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="240" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" Style="{StaticResource PanelScrollStyle}">
                <StackPanel>
                    <GroupBox x:Name="BoxGeneratorPanelGroupBox" Header="Parametry pudelka" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Szerokosc" Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Glebokosc" Style="{StaticResource FieldLabelStyle}" Margin="8,0,0,3" />
                            <TextBox x:Name="BoxWidthTextBox" Grid.Row="1" Grid.Column="0" Text="100" Margin="0,0,4,8" />
                            <TextBox x:Name="BoxDepthTextBox" Grid.Row="1" Grid.Column="1" Text="80" Margin="4,0,0,8" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Wysokosc" Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Material" Style="{StaticResource FieldLabelStyle}" Margin="8,0,0,3" />
                            <TextBox x:Name="BoxHeightTextBox" Grid.Row="3" Grid.Column="0" Text="50" Margin="0,0,4,8" />
                            <TextBox x:Name="MaterialThicknessTextBox" Grid.Row="3" Grid.Column="1" Text="3" Margin="4,0,0,8" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Kerf" Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="Palec" Style="{StaticResource FieldLabelStyle}" Margin="8,0,0,3" />
                            <TextBox x:Name="KerfTextBox" Grid.Row="5" Grid.Column="0" Text="0" Margin="0,0,4,8" />
                            <TextBox x:Name="FingerWidthTextBox" Grid.Row="5" Grid.Column="1" Text="10" Margin="4,0,0,8" />

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Clearance" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="ClearanceTextBox" Grid.Row="7" Grid.Column="0" Text="0" Margin="0,0,4,0" />
                            <Button Grid.Row="7" Grid.Column="1" Content="Przebuduj" Click="RebuildBoxButton_Click" Style="{StaticResource PrimaryButtonStyle}" Margin="4,0,0,0" />
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Bryla trapezowa">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Typ konstrukcji" Style="{StaticResource FieldLabelStyle}" />
                            <ComboBox x:Name="SlopedConstructionTypeComboBox" Grid.Row="1" Grid.ColumnSpan="2" SelectedIndex="1" Margin="0,0,0,8">
                                <ComboBoxItem Content="Prostopadloscian" />
                                <ComboBoxItem Content="Bryla z pochyla gora" />
                                <ComboBoxItem Content="Klin" />
                                <ComboBoxItem Content="Obudowa z pochylonym panelem" />
                                <ComboBoxItem Content="Rynienka trapezowa" />
                            </ComboBox>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Szerokosc" Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Glebokosc" Style="{StaticResource FieldLabelStyle}" Margin="8,0,0,3" />
                            <TextBox x:Name="SlopedWidthTextBox" Grid.Row="3" Grid.Column="0" Text="120" Margin="0,0,4,8" />
                            <TextBox x:Name="SlopedDepthTextBox" Grid.Row="3" Grid.Column="1" Text="80" Margin="4,0,0,8" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Wys. przod" Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="Wys. tyl" Style="{StaticResource FieldLabelStyle}" Margin="8,0,0,3" />
                            <TextBox x:Name="SlopedFrontHeightTextBox" Grid.Row="5" Grid.Column="0" Text="50" Margin="0,0,4,8" />
                            <TextBox x:Name="SlopedBackHeightTextBox" Grid.Row="5" Grid.Column="1" Text="80" Margin="4,0,0,8" />

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Kerf" Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="Material" Style="{StaticResource FieldLabelStyle}" Margin="8,0,0,3" />
                            <TextBox x:Name="SlopedKerfTextBox" Grid.Row="7" Grid.Column="0" Text="0,15" Margin="0,0,4,8" />
                            <TextBlock x:Name="SlopedMaterialNameTextBlock" Grid.Row="7" Grid.Column="1" Text="Sklejka 3 mm" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="8,5,0,8" />

                            <Button Grid.Row="8" Grid.ColumnSpan="2" Content="Dodaj bryle" Click="AddSlopedMaterialSolidFromPanel_Click" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,8" />

                            <TextBlock Grid.Row="9" Grid.ColumnSpan="2" Text="Sciana otworu" Style="{StaticResource FieldLabelStyle}" />
                            <ComboBox x:Name="SlopedCutoutFaceComboBox" Grid.Row="10" Grid.ColumnSpan="2" SelectedIndex="0" Margin="0,0,0,8">
                                <ComboBoxItem Content="Front" />
                                <ComboBoxItem Content="Back" />
                                <ComboBoxItem Content="Left side" />
                                <ComboBoxItem Content="Right side" />
                                <ComboBoxItem Content="Bottom" />
                                <ComboBoxItem Content="Sloped top" />
                            </ComboBox>

                            <TextBlock Grid.Row="11" Grid.Column="0" Text="Srednica" Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock Grid.Row="11" Grid.Column="1" Text="Od lewej" Style="{StaticResource FieldLabelStyle}" Margin="8,0,0,3" />
                            <TextBox x:Name="SlopedCutoutDiameterTextBox" Grid.Row="12" Grid.Column="0" Text="10" Margin="0,0,4,8" />
                            <TextBox x:Name="SlopedCutoutLeftTextBox" Grid.Row="12" Grid.Column="1" Text="20" Margin="4,0,0,8" />

                            <TextBlock Grid.Row="13" Grid.Column="0" Text="Od dolu" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="SlopedCutoutBottomTextBox" Grid.Row="14" Grid.Column="0" Text="20" Margin="0,0,4,0" />
                            <Button Grid.Row="14" Grid.Column="1" Content="Dodaj otwor" ToolTip="Dodaj otwor okragly" Click="AddCircularCutout_Click" Margin="4,0,0,0" />
                            <Button Grid.Row="15" Grid.ColumnSpan="2" Content="Kopiuj otwor na przeciwlegla sciane" Click="CopyCircularCutoutToOppositeFace_Click" Margin="0,8,0,0" />
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Material i warstwy">
                        <StackPanel>
                            <ComboBox x:Name="MaterialProfileComboBox"
                                      DisplayMemberPath="Name"
                                      SelectionChanged="MaterialProfileComboBox_SelectionChanged"
                                      Margin="0,0,0,10" />
                            <ItemsControl x:Name="LayersItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="64" />
                                                <ColumnDefinition Width="64" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Role}" Foreground="{StaticResource MutedTextBrush}" />
                                            <TextBlock Grid.Column="2" Text="{Binding Color.Hex}" Foreground="{StaticResource MutedTextBrush}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Name="TemplateLibraryPanelGroupBox" Header="Biblioteka szablonow" Visibility="Collapsed">
                        <StackPanel>
                            <ComboBox x:Name="LibraryTemplateComboBox"
                                      DisplayMemberPath="Name"
                                      SelectionChanged="LibraryTemplateComboBox_SelectionChanged"
                                      Margin="0,0,0,8" />
                            <TextBlock x:Name="LibraryTemplateDescriptionTextBlock"
                                       Text="Brak szablonu"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8" />
                            <Button Content="Uzyj szablonu" Click="ApplyLibraryTemplate_Click" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Name="KerfPanelGroupBox" Header="Kerf" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Tryb kompensacji" Style="{StaticResource FieldLabelStyle}" />
                            <ComboBox x:Name="KerfModeComboBox" SelectedIndex="0" Margin="0,0,0,8">
                                <ComboBoxItem Content="Positive" />
                                <ComboBoxItem Content="Negative" />
                            </ComboBox>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Content="Nominalny" Click="ShowNominalKerfPreview_Click" Margin="0,0,4,0" />
                                <Button Grid.Column="1" Content="Kerf" Click="ShowCompensatedKerfPreview_Click" Margin="4,0,0,0" />
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Name="KerfCalibrationPanelGroupBox" Header="Kalibracja kerfu" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Szczelina / pomiar mm" Style="{StaticResource FieldLabelStyle}" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="KerfCalibrationSlotIndexTextBox" Text="0" Margin="0,0,4,0" />
                                <TextBox x:Name="KerfCalibrationMeasuredWidthTextBox" Grid.Column="1" Text="20" Margin="4,0,0,0" />
                            </Grid>
                            <TextBlock x:Name="KerfCalibrationRecommendationTextBlock"
                                       Text="Rekomendacja: -"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,0,0,8" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Content="Przelicz" Click="SaveKerfCalibrationMeasurement_Click" Margin="0,0,4,0" />
                                <Button Grid.Column="1" Content="Zapisz profil" Click="SaveKerfRecommendationToProfile_Click" Margin="4,0,0,0" />
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Name="TransformsPanelGroupBox" Header="Transformacje" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Przesuniecie X / Y" Style="{StaticResource FieldLabelStyle}" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="MoveXTextBox" Text="10" Margin="0,0,4,0" />
                                <TextBox x:Name="MoveYTextBox" Grid.Column="1" Text="0" Margin="4,0,0,0" />
                            </Grid>
                            <Button Content="Przesun" Click="MoveSelected_Click" Margin="0,0,0,10" />

                            <TextBlock Text="Obrot w stopniach" Style="{StaticResource FieldLabelStyle}" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="96" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="RotateDegreesTextBox" Text="15" Margin="0,0,8,0" />
                                <Button Grid.Column="1" Content="Obroc" Click="RotateSelected_Click" />
                            </Grid>

                            <TextBlock Text="Skala X / Y" Style="{StaticResource FieldLabelStyle}" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ScaleXTextBox" Text="1,1" Margin="0,0,4,0" />
                                <TextBox x:Name="ScaleYTextBox" Grid.Column="1" Text="1,1" Margin="4,0,0,0" />
                            </Grid>
                            <Button Content="Skaluj" Click="ScaleSelected_Click" />
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="1" Background="#EEF1F5">
                <Grid Margin="8">
                    <Border BorderBrush="#B8C0CC" BorderThickness="1" Background="#FFFFFF">
                        <Grid>
                            <wfi:WindowsFormsHost x:Name="ViewportHost" />
                            <Grid x:Name="ViewportLoadingOverlay" Background="#F8FAFC">
                                <StackPanel Width="300" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border Width="48"
                                            Height="48"
                                            HorizontalAlignment="Center"
                                            Background="#EFF6FF"
                                            BorderBrush="#BFDBFE"
                                            BorderThickness="1"
                                            Margin="0,0,0,16">
                                        <TextBlock Text="LC"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="17"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}" />
                                    </Border>
                                    <TextBlock x:Name="ViewportLoadingTitleTextBlock"
                                               Text="Uruchamianie widoku roboczego"
                                               HorizontalAlignment="Center"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,6" />
                                    <TextBlock x:Name="ViewportLoadingDetailTextBlock"
                                               Text="Ladowanie viewportu Unity..."
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Margin="0,0,0,18" />
                                    <ProgressBar x:Name="ViewportLoadingProgressBar"
                                                 IsIndeterminate="True"
                                                 Style="{StaticResource ViewportLoadingBarStyle}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="2"
                          Background="#FFFFFF"
                          VerticalScrollBarVisibility="Auto"
                          BorderBrush="{StaticResource AppBorderBrush}"
                          BorderThickness="1,0,0,0">
                <StackPanel>
                    <GroupBox x:Name="HistoryPanelGroupBox" Header="Historia" Visibility="Collapsed">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="UndoCountTextBlock" Text="Undo: 0" />
                                <TextBlock x:Name="RedoCountTextBlock" Grid.Column="1" Text="Redo: 0" TextAlignment="Right" Foreground="{StaticResource MutedTextBrush}" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Content="Undo" Click="Undo_Click" Margin="0,0,4,0" />
                                <Button Grid.Column="1" Content="Redo" Click="Redo_Click" Margin="4,0,0,0" />
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Properties">
                        <StackPanel>
                            <TextBlock x:Name="DocumentNameTextBlock" Text="Dokument: Projekt pudelka" Margin="0,0,0,6" />
                            <TextBlock x:Name="SketchCountTextBlock" Text="Szkice: 1" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6" />
                            <TextBlock x:Name="MaterialSolidCountTextBlock" Text="Plyty 3D: 0" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6" />
                            <TextBlock x:Name="SlopedMaterialSolidCountTextBlock" Text="Bryly trapezowe: 0" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6" />
                            <TextBlock Text="Arkusz mm" Style="{StaticResource FieldLabelStyle}" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="SheetWidthTextBox" Text="300" Margin="0,0,4,0" />
                                <TextBox x:Name="SheetHeightTextBox" Grid.Column="1" Text="300" Margin="4,0,0,0" />
                            </Grid>
                            <TextBlock Text="Margines / odstep" Style="{StaticResource FieldLabelStyle}" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="SheetMarginTextBox" Text="5" Margin="0,0,4,0" />
                                <TextBox x:Name="SheetSpacingTextBox" Grid.Column="1" Text="5" Margin="4,0,0,0" />
                            </Grid>
                            <CheckBox x:Name="SheetAllowRotationCheckBox" Content="Obrot 90°" Margin="0,0,0,8" />
                            <Button Content="Przygotuj arkusz" Click="PrepareSheet_Click" Margin="0,0,0,8" />
                            <TextBlock x:Name="NestingSummaryTextBlock" Text="Nesting: -" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,10" />
                            <TextBlock x:Name="SelectedEntitiesTextBlock" Text="Zaznaczone: 0" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,10" />
                            <Button Content="Odswiez zaznaczenie" Click="RefreshSelection_Click" />
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
